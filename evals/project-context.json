    },
    {
      "event": "PreToolUse",
      "matcher": "Write|Edit",
      "command": "gsd-read-guard.js"
    },
    {
      "event": "PreToolUse",
      "matcher": "Write|Edit",
      "command": "gsd-workflow-guard.js"
    },
    {
      "event": "PreToolUse",
      "matcher": "Bash",
      "command": "gsd-validate-commit.sh"
    }
