# infra/hermes-agent/.env.example — copy to `.env` (gitignored). NO real values here.

# --- Hermes's OWN reasoning model (the control plane) ---
# Pick ONE provider (or a local OpenAI-compatible endpoint). Configure via `hermes model`.
# Model-economy note: use the cheapest model that clears the bar for control-plane routing.
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# (local: point Hermes at Ollama/vLLM/llama.cpp — no key)

# --- Claude Code, invoked by Hermes as `claude -p` in project dirs ---
ANTHROPIC_API_KEY=

# --- OpenAI-compatible API server (only if you enable it) ---
# Leave OFF for a local-only control plane. If enabled and bound non-loopback,
# API_SERVER_KEY is MANDATORY (min 8 chars).
# API_SERVER_ENABLED=false
# API_SERVER_HOST=127.0.0.1
# API_SERVER_KEY=
