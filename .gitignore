# Claude Code local session settings (machine-specific paths and permissions)
.claude/settings.local.json

# Git worktrees
.claude/worktrees/

# macOS metadata
.DS_Store
**/.DS_Store

# docs/audits/ is intentionally committed — audit reports are reference artifacts, not volatile outputs

# Codex external eval run artifacts (generated, not versioned)
evals/codex-runs/

# fixtures/ itself is COMMITTED (calibration test assets — see fixtures/README.md),
# but eval runs against the mutant generate a report next to its definition
# (run-native-audit.js --def-path convention); those generated files stay out of git.
fixtures/*/SKILL-EVAL.md
fixtures/*/SKILL.md.eval-snapshot
fixtures/*/SKILL.md.baseline
.project-brain/sessions/

# Hermes Agent runtime (infra/hermes-agent): secrets + persistent state, never committed
infra/hermes-agent/.env
infra/hermes-agent/data/
